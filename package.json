{
  "name": "cf-proxy-relay",
  "version": "1.0.0",
  "private": true,
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.8.19",
    "vitest": "3.2.0",
    "wrangler": "4.51.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "tf:init": "cd terraform && terraform init",
    "tf:plan": "pnpm run build && cd terraform && terraform plan",
    "tf:deploy": "pnpm run build && cd terraform && terraform apply",
    "tf:destroy": "cd terraform && terraform destroy",
    "deploy": "pnpm run tf:deploy"
  }
}
